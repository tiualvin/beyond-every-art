DATABASE_URI=postgresql://payload:payload@localhost:5432/beyond_every_art
PAYLOAD_SECRET=replace-with-a-long-random-development-secret
# One-time administrator bootstrap. Leave unset except while running
# `pnpm bootstrap:admin`, then remove the values from your environment.
PAYLOAD_BOOTSTRAP_EMAIL=
PAYLOAD_BOOTSTRAP_NAME=
PAYLOAD_BOOTSTRAP_PASSWORD=
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 (S3 compatible). Leave unset to use local media storage.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Beyond Every Art
NEXT_PUBLIC_GA_ID=

# Paths only. Never commit the files referenced by these variables.
GHOST_EXPORT_PATH=./ghost-export/ghost-content.json
GHOST_MEDIA_PATH=./ghost-export/content/images
